# ────────────────────────────────────────────────────────────────
# infoproduto-astro — Variáveis de ambiente
# Copie este arquivo para .env.local e preencha os valores.
# NUNCA commite .env.local
# ────────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────────
PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Pagamento — Asaas ────────────────────────────────────────────
# Chave de API (começa com $aact_ em produção, $aact_sandbox em sandbox)
ASAAS_API_KEY=$aact_...

# true para sandbox, false (ou omitir) para produção
ASAAS_SANDBOX=true

# Token de autenticação dos webhooks (configure no painel Asaas)
ASAAS_WEBHOOK_TOKEN=seu_token_secreto

# ── Email — Resend ───────────────────────────────────────────────
RESEND_API_KEY=re_...

# Remetente padrão (sobrescreve PRODUCT.email.from se configurado)
EMAIL_FROM=Meu Produto <noreply@meudominio.com>

# ── WhatsApp (zap-conecta) ───────────────────────────────────────
# Número do WhatsApp gerenciado pelo zap-conecta.
# Formato internacional sem + nem espaços: código país + DDD + número
# Ex: 5511999998888  (55 = Brasil, 11 = SP, 999998888 = número)
# Deixe em branco para desabilitar o botão flutuante.
PUBLIC_WHATSAPP_NUMBER=

# ── App ──────────────────────────────────────────────────────────
# URL base da aplicação (usado em magic links e webhooks)
# Ex: https://meusite.com ou http://localhost:4321 em dev
APP_BASE_URL=http://localhost:4321

---
/**
 * FloatingWhatsApp.astro — Botão flutuante de WhatsApp.
 *
 * Abre uma conversa no número gerenciado pelo zap-conecta via wa.me link.
 * Mensagens recebidas chegam no webhook do zap-conecta automaticamente.
 *
 * Configuração: src/config/product.ts → whatsapp.phone
 * Se phone for undefined, o componente não renderiza nada.
 */

import { PRODUCT } from '../config/product';

// Número vem de PUBLIC_WHATSAPP_NUMBER no .env
// (PUBLIC_ = disponível no browser também — necessário para links wa.me)
const phone    = (import.meta.env.PUBLIC_WHATSAPP_NUMBER as string | undefined)?.trim();
const { prefilledMessage, position } = PRODUCT.whatsapp;

if (!phone) return;

const waUrl    = `https://wa.me/${phone}?text=${encodeURIComponent(prefilledMessage)}`;
const posStyle = position === 'left' ? 'left:1.5rem;right:auto;' : 'right:1.5rem;left:auto;';
---

<a
  id="floating-whatsapp"
  href={waUrl}
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Falar pelo WhatsApp"
  title="Falar pelo WhatsApp"
  style={`position:fixed;bottom:1.5rem;${posStyle}z-index:9999;display:flex;align-items:center;justify-content:center;width:56px;height:56px;background:#25d366;color:#fff;border-radius:50%;text-decoration:none;box-shadow:0 4px 16px rgba(37,211,102,0.45);transition:transform .2s ease,box-shadow .2s ease;`}
>
  <!-- Anel de pulso -->
  <span class="wa-pulse" aria-hidden="true"></span>

  <!-- Ícone WhatsApp (SVG oficial) -->
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="28" height="28" aria-hidden="true">
    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
  </svg>
</a>

<style>
  #floating-whatsapp:hover {
    transform: scale(1.08);
    box-shadow: 0 6px 24px rgba(37, 211, 102, 0.6) !important;
  }

  .wa-pulse {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: #25d366;
    opacity: 0;
    animation: wa-pulse 2.5s ease-out infinite;
  }

  @keyframes wa-pulse {
    0%   { transform: scale(1);    opacity: 0.6; }
    70%  { transform: scale(1.55); opacity: 0;   }
    100% { transform: scale(1.55); opacity: 0;   }
  }

  @media (prefers-reduced-motion: reduce) {
    .wa-pulse { animation: none; }
  }
</style>

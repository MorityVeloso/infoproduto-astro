<!--
  AuthRedirectGuard.astro
  Intercepta tokens de auth do Supabase que caem em páginas erradas
  (quando o Supabase ignora emailRedirectTo e usa o Site URL como fallback).
  Deve ser incluído no <head> de todos os layouts.
-->
<script is:inline>
(function() {
  // Não interceptar páginas de auth que já tratam os tokens
  var p = window.location.pathname;
  if (p === '/auth/callback' || p === '/auth/reset-password') return;

  var hash = window.location.hash;
  var search = window.location.search;

  // Detecta tokens de auth (implicit: #access_token= | PKCE: ?code=)
  var hasImplicitToken = hash && hash.indexOf('access_token=') !== -1;
  var hasPKCECode = search && search.indexOf('code=') !== -1;

  if (hasImplicitToken || hasPKCECode) {
    // Detecta fluxo de recovery (reset de senha) pelo type=recovery no hash ou search
    var isRecovery = (hash && hash.indexOf('type=recovery') !== -1) ||
                     (search && search.indexOf('type=recovery') !== -1);
    var target = isRecovery ? '/auth/reset-password' : '/auth/callback';
    window.location.replace(target + search + hash);
  }
})();
</script>

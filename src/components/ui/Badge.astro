---
interface Props {
  variant?: 'default' | 'accent' | 'muted';
  class?: string;
}

const { variant = 'default', class: className = '' } = Astro.props;

const styles: Record<string, string> = {
  default: `background: var(--color-surface); color: var(--color-text); border: 1px solid var(--color-border);`,
  accent:  `background: var(--color-accent); color: #fff; border: 1px solid transparent;`,
  muted:   `background: transparent; color: var(--color-muted); border: 1px solid var(--color-border);`,
};
---

<span
  style={`
    display: inline-flex;
    align-items: center;
    padding: 0.2rem 0.75rem;
    border-radius: 99px;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    ${styles[variant]}
  `}
  class={className}
>
  <slot />
</span>

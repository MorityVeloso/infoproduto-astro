---
import '../styles/globals.css';
import AuthRedirectGuard from '../components/AuthRedirectGuard.astro';

interface Props {
  title?: string;
  description?: string;
  /** Remove o container max-width do main — necessário para seções full-width */
  fluid?: boolean;
}

const {
  title = 'Quarto de Bebê — Kits de Enxoval Premium',
  description = 'Kits de enxoval de bebê com design minimalista e materiais premium. Feito com amor para o seu momento mais especial.',
  fluid = false,
} = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <AuthRedirectGuard />

    <!-- Google Fonts: Playfair Display + Jost -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Jost:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <!-- Header -->
    <header id="site-header" class="site-header sticky top-0 z-50">
      <div class="header-inner flex items-center justify-between h-16" style="max-width: 1200px; margin: 0 auto; padding: 0 1.5rem;">
        <!-- Logo -->
        <a
          href="/"
          class="logo"
          aria-label="Quarto de Bebê — Página inicial"
        >
          Quarto de Bebê
        </a>

        <!-- Nav links -->
        <nav aria-label="Navegação principal" class="hidden md:flex items-center gap-8">
          <a href="#sobre" class="nav-link">Sobre</a>
          <a href="#kit" class="nav-link">O Kit</a>
          <a href="#modelos" class="nav-link">Modelos</a>
        </nav>

        <!-- CTA -->
        <a href="/checkout" class="header-cta" aria-label="Comprar o kit">
          Quero o Kit
        </a>
      </div>
    </header>

    <!-- Main -->
    <main>
      {fluid ? (
        <slot />
      ) : (
        <div style="max-width: 1200px; margin: 0 auto; padding: 0 1.5rem;">
          <slot />
        </div>
      )}
    </main>

    <!-- Footer -->
    <footer style="border-top: 1px solid var(--color-dark-border); background: var(--color-dark);">
      <div
        style="max-width: 1200px; margin: 0 auto; padding: 2.5rem 1.5rem;"
        class="flex flex-col md:flex-row items-center justify-between gap-4"
      >
        <span style="font-family: var(--font-serif); color: var(--color-cream-35); font-size: 0.9rem;">
          © {new Date().getFullYear()} Quarto de Bebê
        </span>

        <nav aria-label="Links do rodapé" class="flex items-center gap-6">
          <a href="/login" class="footer-link">Área do Cliente</a>
          <a href="#" class="footer-link">Privacidade</a>
          <a href="#" class="footer-link">Termos</a>
        </nav>
      </div>
    </footer>

    <script>
      // Header: transparente no topo, sólido ao rolar
      const header = document.getElementById('site-header');
      if (header) {
        const update = () => {
          if (window.scrollY > 60) {
            header.classList.add('scrolled');
          } else {
            header.classList.remove('scrolled');
          }
        };
        window.addEventListener('scroll', update, { passive: true });
        update();
      }
    </script>
  </body>
</html>

<style>
  .site-header {
    background: transparent;
    border-bottom: 1px solid transparent;
    transition: background 0.3s ease, border-color 0.3s ease, backdrop-filter 0.3s ease;
  }

  .site-header.scrolled {
    background: rgba(15, 13, 11, 0.92);
    border-bottom-color: rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .logo {
    font-family: var(--font-serif);
    color: var(--color-cream);
    font-size: 1.2rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    text-decoration: none;
    transition: color 0.2s;
  }

  .nav-link {
    color: var(--color-cream-60);
    font-size: 0.875rem;
    font-weight: 400;
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: color 0.2s;
  }

  .nav-link:hover {
    color: var(--color-cream);
  }

  .header-cta {
    background: var(--color-gold);
    color: var(--color-dark);
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    padding: 0.5rem 1.25rem;
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: background 0.2s, transform 0.15s;
  }

  .header-cta:hover {
    background: var(--color-gold-hover);
    transform: translateY(-1px);
  }

  .footer-link {
    color: var(--color-cream-35);
    font-size: 0.85rem;
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-link:hover {
    color: var(--color-cream-60);
  }
</style>

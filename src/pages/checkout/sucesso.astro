---
export const prerender = false;

const orderId   = Astro.url.searchParams.get('order') ?? '';
const abVariant = Astro.cookies.get('__ab_variant')?.value ?? 'dark';
---

<!doctype html>
<html lang="pt-BR" data-theme={abVariant}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Compra Confirmada — Meu Produto</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Lora:wght@400;600;700&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,700&display=swap" rel="stylesheet" />
    <!-- Microsoft Clarity -->
    <script type="text/javascript">
      (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window, document, "clarity", "script", "vmgoh2mwde");
    </script>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --qb-dark:   #0F172A;
        --qb-serif:  'Lora', Georgia, serif;
        --qb-sans:   'DM Sans', system-ui, sans-serif;
      }

      body {
        min-height: 100vh;
        background: var(--qb-dark);
        font-family: var(--qb-sans);
        color: #cbd5e1;
        -webkit-font-smoothing: antialiased;
        overflow-x: hidden;
      }

      .main {
        max-width: 896px;
        margin: 0 auto;
        padding: 3rem 1.5rem 4rem;
        position: relative;
        z-index: 10;
      }

      /* Animations */
      @keyframes fadeUp {
        from { opacity: 0; transform: translateY(20px); }
        to   { opacity: 1; transform: translateY(0); }
      }
      @keyframes scaleIn {
        from { opacity: 0; transform: scale(0.85); }
        to   { opacity: 1; transform: scale(1); }
      }
      @keyframes checkDraw {
        to { stroke-dashoffset: 0; }
      }

      .anim-scale { animation: scaleIn 0.5s ease both; }
      .anim-up-1  { animation: fadeUp 0.5s 0.15s ease both; opacity: 0; }
      .anim-up-2  { animation: fadeUp 0.5s 0.25s ease both; opacity: 0; }
      .anim-up-3  { animation: fadeUp 0.5s 0.35s ease both; opacity: 0; }
      .anim-up-4  { animation: fadeUp 0.5s 0.45s ease both; opacity: 0; }

      /* Header */
      .hero { text-align: center; margin-bottom: 4rem; }

      .check-circle {
        width: 96px; height: 96px;
        border-radius: 50%;
        background: rgba(34,197,94,0.2);
        border: 2px solid #22c55e;
        display: flex; align-items: center; justify-content: center;
        margin: 0 auto 1.5rem;
        box-shadow: 0 0 30px rgba(34,197,94,0.3);
      }

      /* Cards */
      .cards { display: grid; grid-template-columns: 1fr; gap: 1.5rem; margin-bottom: 4rem; }
      @media (min-width: 768px) { .cards { grid-template-columns: 1fr 1fr; } }

      .card {
        background: rgba(30,41,59,0.5);
        border: 1px solid #334155;
        border-radius: 16px;
        padding: 2rem;
        position: relative;
        overflow: hidden;
        transition: border-color 0.2s;
      }
      .card:hover { border-color: rgba(34,197,94,0.5); }
      .card.blue:hover { border-color: rgba(59,130,246,0.5); }
      .card::before {
        content: '';
        position: absolute; inset: 0;
        opacity: 0; transition: opacity 0.2s;
        pointer-events: none;
      }
      .card:hover::before { opacity: 1; }
      .card.green::before { background: linear-gradient(135deg, rgba(34,197,94,0.05), transparent); }
      .card.blue::before  { background: linear-gradient(135deg, rgba(59,130,246,0.05), transparent); }

      .card-icon {
        width: 48px; height: 48px;
        border-radius: 8px;
        display: flex; align-items: center; justify-content: center;
        margin-bottom: 1.5rem;
        transition: transform 0.2s;
      }
      .card:hover .card-icon { transform: scale(1.1); }
      .card-icon.green { background: rgba(34,197,94,0.1); border: 1px solid rgba(34,197,94,0.2); }
      .card-icon.blue  { background: rgba(59,130,246,0.1); border: 1px solid rgba(59,130,246,0.2); }

      .card-link {
        display: inline-flex; align-items: center; gap: 0.5rem;
        font-weight: 700; text-decoration: none; transition: color 0.2s;
        background: none; border: none; cursor: pointer; font-family: var(--qb-sans); font-size: 1rem;
      }
      .card-link.green { color: #4ade80; }
      .card-link.green:hover { color: #86efac; }
      .card-link.blue  { color: #60a5fa; }
      .card-link.blue:hover  { color: #93c5fd; }

      /* Steps */
      .steps-section { max-width: 672px; margin: 0 auto; }
      .steps-label {
        text-align: center; font-weight: 700; font-size: 0.75rem;
        letter-spacing: 0.1em; text-transform: uppercase;
        color: #64748b; margin-bottom: 2rem;
      }

      .step-item {
        display: flex; gap: 1.25rem; align-items: flex-start;
        padding: 1rem; border-radius: 8px;
        transition: background 0.2s;
        margin-bottom: 1.5rem;
      }
      .step-item:hover { background: rgba(255,255,255,0.03); }
      .step-num {
        font-family: var(--qb-serif);
        font-size: 1.875rem; font-weight: 700;
        color: #334155; line-height: 1; margin-top: 4px; flex-shrink: 0;
      }

      /* Footer */
      .footer-bar {
        margin-top: 5rem;
        padding-top: 2.5rem;
        border-top: 1px solid #1e293b;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.5rem;
      }
      @media (min-width: 768px) {
        .footer-bar { flex-direction: row; justify-content: space-between; }
      }

      .footer-link {
        font-size: 0.875rem; font-weight: 500;
        color: #64748b; text-decoration: none; transition: color 0.2s;
      }
      .footer-link:hover { color: #fff; }

      .help-btn {
        display: flex; align-items: center; gap: 0.5rem;
        padding: 0.625rem 1.25rem;
        border-radius: 999px;
        background: #1e293b; border: 1px solid #334155;
        color: #cbd5e1; font-family: var(--qb-sans);
        font-size: 0.875rem; font-weight: 700;
        cursor: pointer; transition: background 0.2s, color 0.2s;
      }
      .help-btn:hover { background: #334155; color: #fff; }

      /* ─── White Theme Overrides ──────────────────────────────── */
      [data-theme="white"] body              { background: #FDFCFA; color: #3C3830; }
      [data-theme="white"] h1                { color: #1C1815 !important; }
      [data-theme="white"] h2                { color: #1C1815 !important; }
      [data-theme="white"] h3                { color: #1C1815 !important; }
      [data-theme="white"] p                 { color: #5C5750 !important; }
      [data-theme="white"] strong            { color: #1C1815 !important; }
      [data-theme="white"] .card             { background: #FFFFFF; border-color: rgba(0,0,0,0.09); }
      [data-theme="white"] .card-icon.green  { background: rgba(45,106,64,0.08); border-color: rgba(45,106,64,0.18); }
      [data-theme="white"] .card-icon.blue   { background: rgba(59,130,246,0.08); border-color: rgba(59,130,246,0.18); }
      [data-theme="white"] .step-item:hover  { background: rgba(0,0,0,0.03); }
      [data-theme="white"] .step-num         { color: #C8C0B4; }
      [data-theme="white"] .steps-label      { color: #8C8680; }
      [data-theme="white"] .footer-bar       { border-top-color: rgba(0,0,0,0.08); }
      [data-theme="white"] .footer-link      { color: #8C8680; }
      [data-theme="white"] .footer-link:hover { color: #1C1815; }
      [data-theme="white"] .help-btn         { background: #EDE8E0; border-color: rgba(0,0,0,0.1); color: #1C1815; }
      [data-theme="white"] .help-btn:hover   { background: #E0DAD0; color: #1C1815; }
    </style>
  </head>
  <body>
    <div class="main">

      <!-- Hero -->
      <div class="hero anim-scale">
        <div class="check-circle">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 6 9 17l-5-5"/>
          </svg>
        </div>

        <h1 style="font-family:var(--qb-serif);font-size:clamp(1.75rem,4vw,2.75rem);font-weight:700;color:#fff;margin-bottom:1rem;line-height:1.2;">
          Parabéns! Sua compra foi confirmada.
        </h1>
        <p style="font-size:1.125rem;color:#94a3b8;max-width:560px;margin:0 auto;line-height:1.7;">
          Você acaba de dar o primeiro passo para criar o quarto dos sonhos para o seu bebê. O acesso ao material completo já foi enviado para o seu e-mail.
        </p>

        {orderId && (
          <p style="margin-top:1rem;font-size:0.72rem;color:#475569;font-family:monospace;">
            Pedido: {orderId}
          </p>
        )}
      </div>

      <!-- Action Cards -->
      <div class="cards anim-up-2">

        <div class="card green">
          <div class="card-icon green">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          </div>
          <h3 style="font-family:var(--qb-serif);font-size:1.375rem;font-weight:700;color:#fff;margin-bottom:0.75rem;">Acesse seu e-mail</h3>
          <p style="color:#94a3b8;margin-bottom:1.5rem;line-height:1.6;font-size:0.9375rem;">
            Enviamos um e-mail com o título <span style="color:#fff;font-weight:600;">"Acesso Liberado: Kit Meu Produto"</span> contendo seu login e senha.
          </p>
          <span class="card-link green">
            Ir para meu e-mail
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </span>
        </div>

        <div class="card blue">
          <div class="card-icon blue">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
          </div>
          <h3 style="font-family:var(--qb-serif);font-size:1.375rem;font-weight:700;color:#fff;margin-bottom:0.75rem;">Download Imediato</h3>
          <p style="color:#94a3b8;margin-bottom:1.5rem;line-height:1.6;font-size:0.9375rem;">
            Você também pode baixar o Guia de Primeiros Passos e a Lista de Compras agora mesmo enquanto acessa a plataforma.
          </p>
          <button class="card-link blue">
            Baixar Guia Rápido (PDF)
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
          </button>
        </div>

      </div>

      <!-- Next Steps -->
      <div class="steps-section anim-up-3">
        <p class="steps-label">Próximos Passos</p>

        <div class="step-item">
          <span class="step-num">01</span>
          <div>
            <h4 style="font-weight:700;font-size:1.125rem;color:#fff;margin-bottom:0.375rem;">Verifique sua caixa de entrada</h4>
            <p style="color:#94a3b8;font-size:0.875rem;line-height:1.6;">Procure pelo remetente "Meu Produto" em sua caixa principal, spam ou promoções.</p>
          </div>
        </div>

        <div class="step-item">
          <span class="step-num">02</span>
          <div>
            <h4 style="font-weight:700;font-size:1.125rem;color:#fff;margin-bottom:0.375rem;">Acesse a Área de Membros</h4>
            <p style="color:#94a3b8;font-size:0.875rem;line-height:1.6;">Clique no link do e-mail para configurar sua senha e acessar todos os projetos e materiais.</p>
          </div>
        </div>

        <div class="step-item">
          <span class="step-num">03</span>
          <div>
            <h4 style="font-weight:700;font-size:1.125rem;color:#fff;margin-bottom:0.375rem;">Entre na Comunidade</h4>
            <p style="color:#94a3b8;font-size:0.875rem;line-height:1.6;">No primeiro módulo, você encontrará o link para nosso grupo exclusivo de mães no WhatsApp.</p>
          </div>
        </div>
      </div>

      <!-- Footer -->
      <div class="footer-bar anim-up-4">
        <a href="/" class="footer-link">← Voltar para a Home</a>

        <button class="help-btn">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          Precisa de ajuda?
        </button>
      </div>

    </div>

    <!-- canvas-confetti via CDN -->
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.9.2/dist/confetti.browser.min.js"></script>

    <script>
      import { getOrCreateSessionId, getUtmParams, getVariant } from '../../lib/analytics/client';

      const _sessionId = getOrCreateSessionId();
      const _utms      = getUtmParams();
      const _variant   = getVariant();
      const _orderId   = new URLSearchParams(window.location.search).get('order') ?? undefined;
      const _email     = (() => { try { return localStorage.getItem('__checkout_email') ?? undefined; } catch { return undefined; } })();

      // Track purchase_confirmed
      fetch('/api/events/track', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ event_name: 'purchase_confirmed', session_id: _sessionId, variant: _variant, order_id: _orderId, email: _email, ..._utms }),
      }).catch(() => {});

      // Confetti
      const duration = 3000;
      const end = Date.now() + duration;

      function randomInRange(min: number, max: number) {
        return Math.random() * (max - min) + min;
      }

      const confettiInterval = setInterval(() => {
        const timeLeft = end - Date.now();
        if (timeLeft <= 0) { clearInterval(confettiInterval); return; }

        const particleCount = 50 * (timeLeft / duration);
        const defaults = { startVelocity: 30, spread: 360, ticks: 60, zIndex: 0 };

        (window as any).confetti({ ...defaults, particleCount, origin: { x: randomInRange(0.1, 0.3), y: Math.random() - 0.2 } });
        (window as any).confetti({ ...defaults, particleCount, origin: { x: randomInRange(0.7, 0.9), y: Math.random() - 0.2 } });
      }, 250);
    </script>
  </body>
</html>

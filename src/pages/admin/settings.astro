---
// src/pages/admin/settings.astro
export const prerender = false;

import AdminLayout from '../../layouts/AdminLayout.astro';
import { requireAdmin } from '../../lib/require-admin';
import { createAdminClient } from '../../lib/supabase/admin';

const result = await requireAdmin(Astro.request);
if (result.redirectUrl) return Astro.redirect(result.redirectUrl);
const profile = result.profile!;

const admin = createAdminClient();
const { data: rows } = await admin
  .from('site_settings')
  .select('key, value')
  .in('key', ['whatsapp_number', 'whatsapp_message']);

const settings: Record<string, string> = {};
for (const row of (rows ?? []) as { key: string; value: string }[]) {
  settings[row.key] = row.value;
}
---

<AdminLayout title="Configurações — Admin" email={profile.email}>
  <style>
    @keyframes fadeInUp {
      from { opacity: 0; transform: translateY(12px); }
      to   { opacity: 1; transform: none; }
    }

    .page-header   { margin-bottom: 2rem; animation: fadeInUp 0.4s ease both; }
    .page-title    { display: flex; align-items: center; gap: 0.55rem; font-size: 1.6rem; font-weight: 700; color: var(--color-text); margin: 0 0 0.3rem; }
    .page-title svg { flex-shrink: 0; color: var(--accent, #6366f1); }
    .page-subtitle { color: var(--color-muted); font-size: 0.9rem; margin: 0; }

    .section       {
      background: var(--card, rgba(17,24,39,0.8));
      backdrop-filter: blur(12px);
      border: 1px solid var(--border, rgba(255,255,255,0.08));
      border-radius: 12px;
      padding: 1.5rem;
      margin-bottom: 1.5rem;
      animation: fadeInUp 0.4s ease 0.08s both;
    }
    .section-title { font-size: 1rem; font-weight: 700; color: var(--color-text); margin: 0 0 0.25rem; display: flex; align-items: center; gap: 0.5rem; }
    .section-desc  { color: var(--color-muted); font-size: 0.82rem; margin: 0 0 1.5rem; }

    .field         { margin-bottom: 1.25rem; }
    .field:last-of-type { margin-bottom: 0; }
    .field-label   { display: block; font-size: 0.85rem; font-weight: 600; color: var(--color-text); margin-bottom: 0.35rem; }
    .field-hint    { font-size: 0.78rem; color: var(--color-muted); margin: 0.3rem 0 0; }

    .field-row     { display: flex; gap: 0.6rem; align-items: flex-start; }

    input[type="text"],
    textarea {
      flex: 1;
      padding: 0.5rem 0.75rem;
      border-radius: 6px;
      border: 1px solid var(--color-border);
      background: var(--color-surface);
      color: var(--color-text);
      font-family: var(--font-sans);
      font-size: 0.875rem;
      transition: border-color 0.15s;
      min-width: 0;
    }
    input[type="text"]:focus,
    textarea:focus {
      outline: none;
      border-color: var(--accent, #6366f1);
    }
    textarea { resize: vertical; min-height: 120px; }

    .btn-save {
      padding: 0.5rem 1.1rem;
      border-radius: 6px;
      border: none;
      background: var(--accent, #6366f1);
      color: #fff;
      cursor: pointer;
      font-size: 0.82rem;
      font-weight: 600;
      white-space: nowrap;
      transition: background 0.15s;
      flex-shrink: 0;
    }
    .btn-save:hover    { background: var(--accent-hover, #4f46e5); }
    .btn-save:disabled { opacity: 0.5; cursor: default; }

    .status-msg        { font-size: 0.8rem; margin-top: 0.4rem; min-height: 1.1rem; }
    .status-msg.ok     { color: #4ade80; }
    .status-msg.err    { color: #f87171; }

    .wa-icon { color: #25d366; }

    @media (max-width: 640px) {
      .field-row { flex-direction: column; }
      .btn-save { align-self: flex-start; }
    }
  </style>

  <div class="page-header">
    <h1 class="page-title">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></svg>
      Configurações
    </h1>
    <p class="page-subtitle">Gerencie as integrações da landing page sem precisar de redeploy.</p>
  </div>

  <!-- WhatsApp -->
  <div class="section">
    <h2 class="section-title">
      <svg class="wa-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      WhatsApp
    </h2>
    <p class="section-desc">Configurações do botão flutuante de WhatsApp na landing page.</p>

    <div class="field">
      <label class="field-label" for="whatsapp_number">Número do WhatsApp</label>
      <div class="field-row">
        <input
          type="text"
          id="whatsapp_number"
          data-key="whatsapp_number"
          placeholder="5511999998888"
          value={settings['whatsapp_number'] ?? ''}
          autocomplete="off"
          spellcheck="false"
        />
        <button class="btn-save" data-key="whatsapp_number">Salvar</button>
      </div>
      <p class="field-hint">Formato internacional sem + nem espaços. Ex: 5511999998888 (55 = Brasil, 11 = DDD, 999998888 = número)</p>
      <p class="status-msg" id="status-whatsapp_number" aria-live="polite"></p>
    </div>

    <div class="field">
      <label class="field-label" for="whatsapp_message">Mensagem pré-preenchida</label>
      <div class="field-row">
        <textarea
          id="whatsapp_message"
          data-key="whatsapp_message"
          rows="3"
          placeholder="Olá! Tenho uma dúvida sobre o produto."
        >{settings['whatsapp_message'] ?? ''}</textarea>
        <button class="btn-save" data-key="whatsapp_message">Salvar</button>
      </div>
      <p class="field-hint">Texto que aparece pré-preenchido ao abrir o WhatsApp. Deixe vazio para usar o padrão.</p>
      <p class="status-msg" id="status-whatsapp_message" aria-live="polite"></p>
    </div>
  </div>

  <script>
    document.querySelectorAll<HTMLButtonElement>('.btn-save').forEach(btn => {
      const key    = btn.dataset.key!;
      const input  = document.getElementById(key) as HTMLInputElement | HTMLTextAreaElement;
      const status = document.getElementById(`status-${key}`)!;

      btn.addEventListener('click', async () => {
        const value = input.value.trim();
        btn.disabled = true;
        status.className = 'status-msg';
        status.textContent = 'Salvando…';

        try {
          const res  = await fetch('/api/admin/site-settings/update', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ key, value }),
          });
          const json = await res.json() as { ok?: boolean; error?: string };

          if (!res.ok || !json.ok) {
            status.className = 'status-msg err';
            status.textContent = json.error ?? 'Erro ao salvar.';
          } else {
            status.className = 'status-msg ok';
            status.textContent = 'Salvo com sucesso!';
          }
        } catch {
          status.className = 'status-msg err';
          status.textContent = 'Erro de rede. Tente novamente.';
        } finally {
          btn.disabled = false;
        }
      });
    });
  </script>

  <script>
    const observer = new MutationObserver((mutations) => {
      for (const m of mutations) {
        const el = m.target as HTMLElement;
        if (el.classList.contains('ok')) {
          setTimeout(() => {
            el.className = 'status-msg';
            el.textContent = '';
          }, 4000);
        }
      }
    });
    document.querySelectorAll('.status-msg').forEach(el => {
      observer.observe(el, { attributes: true, attributeFilter: ['class'] });
    });
  </script>

  <script>
    const waInput = document.getElementById('whatsapp_number') as HTMLInputElement;
    if (waInput) {
      waInput.setAttribute('inputmode', 'numeric');
      waInput.addEventListener('input', () => {
        const val = waInput.value.trim();
        if (val === '') {
          waInput.style.borderColor = '';
        } else {
          const valid = /^[0-9]{10,15}$/.test(val);
          waInput.style.borderColor = valid ? '#4ade80' : '#ef4444';
        }
      });
    }
  </script>
</AdminLayout>

---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import { requireAdmin } from '../../lib/require-admin';

const result = await requireAdmin(Astro.request);
if (result.redirectUrl) return Astro.redirect(result.redirectUrl);
const { profile } = result;
---

<AdminLayout title="Pedidos — Admin" email={profile.email}>
  <div class="orders-page">
    <h1 class="page-title">Pedidos</h1>

    <div class="filter-bar">
      <select id="filter-status" aria-label="Filtrar por status">
        <option value="">Todos os status</option>
        <option value="pending">Pendente</option>
        <option value="paid">Pago</option>
        <option value="cancelled">Cancelado</option>
        <option value="refunded">Reembolsado</option>
      </select>

      <input
        id="filter-email"
        type="search"
        placeholder="Buscar por e-mail"
        aria-label="Buscar por e-mail"
      />

      <div class="date-buttons" role="group" aria-label="Período">
        <button class="date-btn active" data-days="0">Todos</button>
        <button class="date-btn" data-days="30">30 dias</button>
        <button class="date-btn" data-days="7">7 dias</button>
      </div>
    </div>

    <div
      id="orders-region"
      role="region"
      aria-label="Lista de pedidos"
      aria-live="polite"
    >
      <p id="orders-loading">Carregando...</p>
    </div>

    <div id="pagination" class="pagination" hidden>
      <button id="prev-page" aria-label="Página anterior">&#8592; Anterior</button>
      <span id="page-info"></span>
      <button id="next-page" aria-label="Próxima página">Próxima &#8594;</button>
    </div>
  </div>
</AdminLayout>

<style>
  .orders-page { padding: 1.5rem; }
  .page-title  { margin: 0 0 1.5rem; font-size: 1.5rem; }

  .filter-bar {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 1.25rem;
    align-items: center;
  }
  .filter-bar select,
  .filter-bar input {
    padding: 0.4rem 0.6rem;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    background: var(--color-surface);
    color: var(--color-text);
    font-size: 0.875rem;
  }
  .filter-bar input { flex: 1; min-width: 200px; }

  .date-buttons { display: flex; gap: 0.4rem; }
  .date-btn {
    padding: 0.4rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    background: var(--color-surface);
    color: var(--color-text);
    font-size: 0.875rem;
    cursor: pointer;
    transition: background 0.15s;
  }
  .date-btn.active {
    background: var(--color-accent2);
    color: #fff;
    border-color: var(--color-accent2);
  }

  #orders-region { overflow-x: auto; -webkit-overflow-scrolling: touch; }
  .orders-table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
  @media (max-width: 768px) { .col-hide-mobile { display: none; } }
  .orders-table th,
  .orders-table td {
    padding: 0.625rem 0.75rem;
    text-align: left;
    border-bottom: 1px solid var(--color-border);
  }
  .orders-table th { font-weight: 600; color: var(--color-muted); }
  .orders-table tbody tr:not(.detail-row):hover {
    background: var(--color-surface-hover, rgba(0,0,0,0.03));
  }

  .badge {
    display: inline-block;
    padding: 0.2rem 0.5rem;
    border-radius: 99px;
    font-size: 0.75rem;
    font-weight: 500;
  }
  .badge-paid      { background: rgba(34,197,94,0.15);  color: #4ade80; }
  .badge-pending   { background: rgba(251,191,36,0.15); color: #fbbf24; }
  .badge-cancelled { background: rgba(239,68,68,0.15);  color: #f87171; }
  .badge-refunded  { background: rgba(99,102,241,0.15); color: #a5b4fc; }

  .detail-row td {
    background: var(--color-surface);
    padding: 1rem 1.5rem;
  }
  .detail-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 0.75rem;
  }
  .detail-label { font-size: 0.75rem; color: var(--color-muted); margin-bottom: 0.2rem; }
  .detail-value { font-size: 0.875rem; word-break: break-all; }

  .action-btn {
    padding: 0.3rem 0.6rem;
    font-size: 0.8rem;
    border: 1px solid var(--color-border);
    border-radius: 5px;
    background: var(--color-surface);
    color: var(--color-text);
    cursor: pointer;
    margin-right: 0.35rem;
    transition: background 0.15s;
  }
  .action-btn:hover:not(:disabled) { background: var(--color-surface-hover, #f5f5f5); }
  .action-btn:disabled { opacity: 0.5; cursor: default; }

  .pagination {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 1rem;
    font-size: 0.875rem;
  }
  .pagination button {
    padding: 0.4rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    background: var(--color-surface);
    color: var(--color-text);
    cursor: pointer;
  }
  .pagination button:disabled { opacity: 0.4; cursor: default; }

  .error-msg { color: var(--color-error, #dc2626); }
  .retry-btn {
    margin-left: 0.5rem;
    padding: 0.2rem 0.5rem;
    font-size: 0.8rem;
    border: 1px solid currentColor;
    border-radius: 4px;
    background: transparent;
    cursor: pointer;
    color: inherit;
  }
</style>

<script>
  interface Order {
    id: string;
    customer_id: string | null;
    customer_email: string;
    status: string;
    amount_total: number;
    selected_model: string | null;
    selected_size: string | null;
    created_at: string;
    paid_at: string | null;
    email_sent_at: string | null;
    entitlement_active: boolean | null;
  }

  interface ApiResponse {
    orders: Order[];
    total: number;
    page: number;
    pageSize: number;
  }

  const region     = document.getElementById('orders-region')!;
  const pagination = document.getElementById('pagination') as HTMLDivElement;
  const pageInfo   = document.getElementById('page-info')!;
  const prevBtn    = document.getElementById('prev-page') as HTMLButtonElement;
  const nextBtn    = document.getElementById('next-page') as HTMLButtonElement;
  const statusSel  = document.getElementById('filter-status') as HTMLSelectElement;
  const emailInput = document.getElementById('filter-email') as HTMLInputElement;
  const dateBtns   = document.querySelectorAll<HTMLButtonElement>('.date-btn');

  let currentPage   = 1;
  let currentTotal  = 0;
  let currentDays   = 0;
  let emailDebounce = 0;

  const PAGE_SIZE = 25;

  const fmtDate = (() => {
    const fmt = new Intl.DateTimeFormat('pt-BR', { day: '2-digit', month: '2-digit', year: 'numeric' });
    return (iso: string | null) => iso ? fmt.format(new Date(iso)) : '—';
  })();

  const fmtBRL = (n: number) =>
    new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(n);

  const BADGE_CLASS: Record<string, string> = {
    paid: 'badge-paid', pending: 'badge-pending',
    cancelled: 'badge-cancelled', refunded: 'badge-refunded',
  };
  const STATUS_LABEL: Record<string, string> = {
    paid: 'Pago', pending: 'Pendente',
    cancelled: 'Cancelado', refunded: 'Reembolsado',
  };

  function makeBadge(status: string): HTMLSpanElement {
    const span = document.createElement('span');
    span.className = 'badge ' + (BADGE_CLASS[status] ?? '');
    span.textContent = STATUS_LABEL[status] ?? status;
    return span;
  }

  function makeDetailRow(order: Order): HTMLTableRowElement {
    const tr = document.createElement('tr');
    tr.className = 'detail-row';
    tr.dataset.detailFor = order.id;

    const td = document.createElement('td');
    td.colSpan = window.innerWidth <= 768 ? 4 : 9;

    const grid = document.createElement('div');
    grid.className = 'detail-grid';

    const fields: Array<[string, string]> = [
      ['ID completo',  order.id],
      ['E-mail',       order.customer_email],
      ['Customer ID',  order.customer_id ?? '—'],
      ['Modelo',       order.selected_model ?? '—'],
      ['Tamanho',      order.selected_size ?? '—'],
      ['Criado em',    fmtDate(order.created_at)],
      ['Pago em',      fmtDate(order.paid_at)],
      ['Entitlement',  order.entitlement_active === null ? 'N/A' : order.entitlement_active ? 'Ativo' : 'Inativo'],
    ];

    for (const [label, value] of fields) {
      const item = document.createElement('div');

      const lbl = document.createElement('div');
      lbl.className = 'detail-label';
      lbl.textContent = label;

      const val = document.createElement('div');
      val.className = 'detail-value';
      val.textContent = value;

      item.append(lbl, val);
      grid.appendChild(item);
    }

    td.appendChild(grid);
    tr.appendChild(td);
    return tr;
  }

  function toggleDetail(order: Order, row: HTMLTableRowElement, tbody: HTMLTableSectionElement): void {
    const existing = tbody.querySelector(`tr[data-detail-for="${CSS.escape(order.id)}"]`);
    if (existing) { existing.remove(); return; }

    tbody.querySelectorAll<HTMLTableRowElement>('.detail-row').forEach(r => r.remove());
    row.insertAdjacentElement('afterend', makeDetailRow(order));
  }

  async function resendAccess(orderId: string, btn: HTMLButtonElement): Promise<void> {
    const orig = btn.textContent ?? '';
    btn.textContent = 'Enviando...';
    btn.disabled = true;
    try {
      const res = await fetch('/api/admin/orders/resend-access', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ orderId }),
      });
      btn.textContent = res.ok ? 'Enviado!' : 'Erro';
    } catch {
      btn.textContent = 'Erro';
    } finally {
      window.setTimeout(() => { btn.textContent = orig; btn.disabled = false; }, 2000);
    }
  }

  async function toggleEntitlement(
    customerId: string,
    activate: boolean,
    btn: HTMLButtonElement,
    order: Order,
  ): Promise<void> {
    btn.disabled = true;
    try {
      const res = await fetch('/api/admin/orders/toggle-entitlement', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ customerId, active: activate }),
      });
      if (res.ok) {
        order.entitlement_active = activate;
        btn.textContent = activate ? 'Desativar acesso' : 'Ativar acesso';
      } else {
        btn.textContent = 'Erro';
        window.setTimeout(() => {
          btn.textContent = order.entitlement_active ? 'Desativar acesso' : 'Ativar acesso';
        }, 2000);
      }
    } finally {
      btn.disabled = false;
    }
  }

  function appendRow(order: Order, tbody: HTMLTableSectionElement): void {
    const tr = document.createElement('tr');
    tr.dataset.orderId = order.id;

    const emailCell = (() => {
      const span = document.createElement('span');
      if (order.email_sent_at) {
        span.textContent = '✓ ' + fmtDate(order.email_sent_at);
        span.style.color = '#4ade80';
        span.style.fontSize = '0.8rem';
      } else {
        span.textContent = '—';
        span.style.color = 'var(--color-muted)';
      }
      return span;
    })();

    const cells: Array<string | HTMLElement> = [
      order.id.slice(0, 8),
      order.customer_email,
      makeBadge(order.status),
      fmtBRL(order.amount_total),
      order.selected_model ?? '—',
      order.selected_size ?? '—',
      fmtDate(order.created_at),
      emailCell,
    ];

    const HIDE_COLS = new Set([0, 4, 5, 6, 7]);
    for (const [i, cell] of cells.entries()) {
      const td = document.createElement('td');
      if (typeof cell === 'string') { td.textContent = cell; }
      else { td.appendChild(cell); }
      if (HIDE_COLS.has(i)) td.className = 'col-hide-mobile';
      tr.appendChild(td);
    }

    const actionsTd = document.createElement('td');

    const detailBtn = document.createElement('button');
    detailBtn.className = 'action-btn';
    detailBtn.textContent = 'Detalhes';
    detailBtn.addEventListener('click', () => toggleDetail(order, tr, tbody));

    const resendBtn = document.createElement('button');
    resendBtn.className = 'action-btn';
    resendBtn.textContent = 'Reenviar acesso';
    resendBtn.addEventListener('click', () => resendAccess(order.id, resendBtn));

    actionsTd.append(detailBtn, resendBtn);

    if (order.customer_id) {
      const toggleBtn = document.createElement('button');
      toggleBtn.className = 'action-btn';
      toggleBtn.textContent = order.entitlement_active ? 'Desativar acesso' : 'Ativar acesso';
      toggleBtn.addEventListener('click', () =>
        toggleEntitlement(order.customer_id!, !order.entitlement_active, toggleBtn, order)
      );
      actionsTd.appendChild(toggleBtn);
    }

    tr.appendChild(actionsTd);
    tbody.appendChild(tr);
  }

  function renderOrders(data: ApiResponse): void {
    region.textContent = '';

    if (data.orders.length === 0) {
      const p = document.createElement('p');
      p.textContent = 'Nenhum pedido encontrado.';
      region.appendChild(p);
      pagination.hidden = true;
      return;
    }

    const table = document.createElement('table');
    table.className = 'orders-table';

    const HIDE_MOBILE_COLS = new Set([0, 4, 5, 6, 7]); // ID, Modelo, Tamanho, Data, Email-sent
    const thead = document.createElement('thead');
    const headRow = document.createElement('tr');
    for (const [i, h] of (['ID', 'E-mail', 'Status', 'Valor', 'Modelo', 'Tamanho', 'Data', 'Email', 'Ações'] as const).entries()) {
      const th = document.createElement('th');
      th.textContent = h;
      if (HIDE_MOBILE_COLS.has(i)) th.className = 'col-hide-mobile';
      headRow.appendChild(th);
    }
    thead.appendChild(headRow);
    table.appendChild(thead);

    const tbody = document.createElement('tbody');
    for (const order of data.orders) appendRow(order, tbody);
    table.appendChild(tbody);
    region.appendChild(table);

    currentTotal = data.total;
    const totalPages = Math.max(1, Math.ceil(currentTotal / PAGE_SIZE));
    pageInfo.textContent = `Página ${currentPage} de ${totalPages} (${currentTotal} pedidos)`;
    prevBtn.disabled = currentPage <= 1;
    nextBtn.disabled = currentPage >= totalPages;
    pagination.hidden = false;
  }

  async function loadOrders(): Promise<void> {
    region.textContent = '';
    const loading = document.createElement('p');
    loading.textContent = 'Carregando...';
    region.appendChild(loading);
    pagination.hidden = true;

    const params = new URLSearchParams({
      page: String(currentPage),
      pageSize: String(PAGE_SIZE),
    });
    const statusVal = statusSel.value;
    const emailVal  = emailInput.value.trim();
    if (statusVal) params.set('status', statusVal);
    if (emailVal)  params.set('q', emailVal);
    if (currentDays > 0) params.set('days', String(currentDays));

    try {
      const res = await fetch('/api/admin/orders?' + params.toString());
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data: ApiResponse = await res.json();
      renderOrders(data);
    } catch {
      region.textContent = '';
      const p = document.createElement('p');
      p.className = 'error-msg';
      p.textContent = 'Erro ao carregar pedidos.';

      const retryBtn = document.createElement('button');
      retryBtn.className = 'retry-btn';
      retryBtn.textContent = 'Tentar novamente';
      retryBtn.addEventListener('click', loadOrders);
      p.appendChild(retryBtn);
      region.appendChild(p);
    }
  }

  statusSel.addEventListener('change', () => { currentPage = 1; loadOrders(); });

  emailInput.addEventListener('input', () => {
    window.clearTimeout(emailDebounce);
    emailDebounce = window.setTimeout(() => { currentPage = 1; loadOrders(); }, 400);
  });

  dateBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      dateBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      currentDays = Number(btn.dataset.days ?? '0');
      currentPage = 1;
      loadOrders();
    });
  });

  prevBtn.addEventListener('click', () => { currentPage--; loadOrders(); });
  nextBtn.addEventListener('click', () => { currentPage++; loadOrders(); });

  loadOrders();
</script>
